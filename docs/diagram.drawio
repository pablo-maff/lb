<mxfile host="app.diagrams.net" version="21.7.5">
  <diagram id="request-flow" name="Request Flow">
    <mxGraphModel grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- LB container -->
        <mxCell id="rf-lb" value="Load Balancer (:3030)" style="swimlane;fontStyle=1;align=center;startSize=30;dashed=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="660" height="400" as="geometry" />
        </mxCell>

        <!-- Inside LB (coords relative to swimlane, y offset by startSize=30) -->
        <mxCell id="rf-handler" value="lb handler" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="rf-lb">
          <mxGeometry x="230" y="40" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf-maxcheck" value="Max attempts reached?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="rf-lb">
          <mxGeometry x="205" y="120" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="rf-503a" value="503 Service Unavailable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="rf-lb">
          <mxGeometry x="20" y="250" width="170" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf-pool" value="ServerPool.GetNextPeer&#xa;round-robin, skip dead" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="rf-lb">
          <mxGeometry x="390" y="245" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rf-503b" value="503 Service Unavailable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="rf-lb">
          <mxGeometry x="420" y="330" width="170" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf-proxy" value="ReverseProxy.ServeHTTP" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="rf-lb">
          <mxGeometry x="210" y="330" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- Outside LB -->
        <mxCell id="rf-client" value="Client" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="340" y="20" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf-b1" value="Backend A" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="820" y="270" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf-b2" value="Backend B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="820" y="340" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf-b3" value="Backend N" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="820" y="410" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf-eh" value="ErrorHandler" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="490" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf-retry" value="wait 10ms&#xa;retry same backend" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="590" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rf-mark" value="MarkBackendStatus dead&#xa;increment attempts" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="590" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" value="HTTP request" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-client" target="rf-handler" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="attempts &gt; 3?" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-handler" target="rf-maxcheck" parent="rf-lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="yes" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-maxcheck" target="rf-503a" parent="rf-lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="no" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-maxcheck" target="rf-pool" parent="rf-lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="no alive peers" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-pool" target="rf-503b" parent="rf-lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="peer found" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-pool" target="rf-proxy" parent="rf-lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="forward request" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-proxy" target="rf-b1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="forward request" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-proxy" target="rf-b2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" value="forward request" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-proxy" target="rf-b3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" value="error" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-proxy" target="rf-eh" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" value="retries &lt; 3" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-eh" target="rf-retry" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-retry" target="rf-proxy" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13" value="retries = 3" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="rf-eh" target="rf-mark" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14" value="recurse" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="rf-mark" target="rf-handler" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1040" y="615" />
              <mxPoint x="1040" y="160" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

